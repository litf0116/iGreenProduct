# =============================================================================
# 环境变量配置说明 (已弃用)
# =============================================================================
# 
# 注意：本项目已移除环境变量配置，改为在代码中直接配置 API 地址。
# 
# API 地址配置位置：src/lib/api.ts
# 
// 生产环境服务器地址
#const API_BASE_URL = 'http://43.255.212.68:8088';

// 可选的备用地址（请手动取消注释切换）：
// const API_BASE_URL = 'http://43.255.212.68:8080';
const API_BASE_URL = 'http://localhost:8089'; // 本地开发
// const API_BASE_URL = 'http://192.168.10.154:8088'; // 内网测试

# =============================================================================
# 修改步骤：
# 1. 编辑 src/lib/api.ts 文件
# 2. 找到 API_BASE_URL 常量定义
# 3. 修改为所需的服务器地址
# 4. 重新构建应用：npm run package
# =============================================================================
# 生产环境
#VITE_API_URL=http://43.255.212.68:8080

# 开发环境示例
VITE_API_URL=http://localhost:8089
