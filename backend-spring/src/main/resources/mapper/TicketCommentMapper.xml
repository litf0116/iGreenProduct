<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.igreen.domain.mapper.TicketCommentMapper">

    <resultMap id="BaseResultMap" type="com.igreen.domain.entity.TicketComment">
        <id property="id" column="id"/>
        <result property="comment" column="comment"/>
        <result property="type" column="type"/>
        <result property="ticketId" column="ticket_id"/>
        <result property="userId" column="user_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="TicketCommentWithUserResultMap" type="com.igreen.domain.entity.TicketComment" extends="BaseResultMap">
        <association property="user" javaType="com.igreen.domain.entity.User">
            <id property="id" column="user_id"/>
            <result property="name" column="user_name"/>
            <result property="username" column="user_username"/>
        </association>
    </resultMap>

    <sql id="Base_Column_List">
        id, comment, type, ticket_id, user_id, created_at
    </sql>

    <select id="selectByTicketIdOrderByCreatedAtAsc" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ticket_comments
        WHERE ticket_id = #{ticketId}
        ORDER BY created_at ASC
    </select>

    <select id="selectByTicketIdWithUser" resultMap="TicketCommentWithUserResultMap">
        SELECT tc.*, u.name as user_name, u.username as user_username
        FROM ticket_comments tc
        LEFT JOIN users u ON tc.user_id = u.id
        WHERE tc.ticket_id = #{ticketId}
        ORDER BY tc.created_at ASC
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ticket_comments
        WHERE user_id = #{userId}
    </select>

    <select id="selectByTicketIdAndType" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ticket_comments
        WHERE ticket_id = #{ticketId} AND type = #{type}
    </select>

</mapper>
