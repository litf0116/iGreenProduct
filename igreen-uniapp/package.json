{
  "name": "igreen-uniapp",
  "version": "1.0.0",
  "private": true,
  "description": "iGreen+ Engineer Mobile App - Built with uni-app",
  "scripts": {
    "dev": "npm run dev:h5",
    "dev:h5": "npx @dcloudio/uni-app-cli -p h5",
    "dev:app": "npx @dcloudio/uni-app-cli -p app-plus",
    "dev:mp-weixin": "npx @dcloudio/uni-app-cli -p mp-weixin",
    "build": "npm run build:h5",
    "build:h5": "npx @dcloudio/uni-app-cli build --platform h5",
    "build:app": "npx @dcloudio/uni-app-cli build --platform app-plus",
    "build:mp-weixin": "npx @dcloudio/uni-app-cli build --platform mp-weixin",
    "generate:icons": "python3 scripts/upscale_icon.py",
    "install:cli": "npm install @dcloudio/uni-app-cli --no-save"
  },
  "dependencies": {
    "@dcloudio/uni-app": "^3.0.0-3090920231225001",
    "@dcloudio/uni-h5": "^3.0.0-3090920231225001",
    "pinia": "^2.1.7",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "sass": "^1.32.0",
    "sass-loader": "^8.0.2",
    "typescript": "^4.9.5"
  },
  "uni-app": {
    "scripts": {
      "dev:h5": {
        "BROWSER": "chrome",
        "env": "development",
        "define": {
          "H5": true
        }
      },
      "dev:app": {
        "env": "development"
      }
    }
  }
}
