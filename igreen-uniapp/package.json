{
  "name": "igreen-uniapp",
  "version": "1.0.0",
  "private": true,
  "description": "iGreen+ Engineer Mobile App - Built with uni-app",
  "scripts": {
    "dev": "npm run dev:h5",
    "dev:h5": "hbx run --platform h5",
    "dev:app": "hbx run --platform app",
    "dev:mp-weixin": "hbx run --platform mp-weixin",
    "build": "npm run build:h5",
    "build:h5": "hbx build --platform h5",
    "build:app": "hbx build --platform app",
    "build:mp-weixin": "hbx build --platform mp-weixin",
    "build:android": "npm run build:app && ./scripts/build-android.sh",
    "setup:android": "./scripts/setup-android-pack.sh",
    "install:hbx-cli": "./scripts/install-hbx-cli.sh",
    "generate:icons": "python3 scripts/upscale_icon.py"
  },
  "dependencies": {
    "@dcloudio/uni-app": "^3.0.0-3090920231225001",
    "@dcloudio/uni-h5": "^3.0.0-3090920231225001",
    "pinia": "^2.1.7",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "sass": "^1.32.0",
    "typescript": "^4.9.5"
  },
  "uni-app": {
    "scripts": {
      "dev:h5": {
        "BROWSER": "chrome",
        "env": "development",
        "define": {
          "H5": true
        }
      },
      "dev:app": {
        "env": "development"
      }
    }
  }
}
