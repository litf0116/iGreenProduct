# Application Configuration
APP_NAME=iGreen+ Unified Backend
APP_VERSION=1.0.0
DEBUG=True

# Database Configuration
# 开发环境可以使用sqlite，生产环境使用mysql
DATABASE_TYPE=sqlite
# DATABASE_TYPE=mysql

# MySQL Database Configuration (仅当DATABASE_TYPE=mysql时需要配置)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=igreen_user
DATABASE_PASSWORD=your_secure_password_here
DATABASE_NAME=igreen_db

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# CORS Configuration
# 多个源用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Face Recognition (optional)
FACE_RECOGNITION_API_URL=
FACE_RECOGNITION_API_KEY=
