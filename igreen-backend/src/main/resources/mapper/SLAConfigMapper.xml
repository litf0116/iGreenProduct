<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.igreen.domain.mapper.SLAConfigMapper">

    <resultMap id="SLAConfigResultMap" type="com.igreen.domain.entity.SLAConfig">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="responseTimeHours" column="response_time_hours"/>
        <result property="resolutionTimeHours" column="resolution_time_hours"/>
        <result property="priority" column="priority"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, response_time_hours, resolution_time_hours, priority, created_at, updated_at
    </sql>

    <select id="selectByPriority" resultMap="SLAConfigResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sla_configs
        WHERE priority = #{priority}
    </select>

</mapper>
