<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.igreen.domain.mapper.TicketAttachmentMapper">

    <resultMap id="BaseResultMap" type="com.igreen.domain.entity.TicketAttachment">
        <id property="id" column="id"/>
        <result property="ticketId" column="ticket_id"/>
        <result property="fileId" column="file_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, ticket_id, file_id, created_at
    </sql>

    <select id="selectByTicketId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ticket_attachments
        WHERE ticket_id = #{ticketId}
    </select>

    <insert id="insertBatch" parameterType="java.util.List">
        INSERT INTO ticket_attachments (id, ticket_id, file_id, created_at)
        VALUES
        <foreach collection="attachments" item="item" separator=",">
            (#{item.id}, #{item.ticketId}, #{item.fileId}, #{item.createdAt})
        </foreach>
    </insert>

    <delete id="deleteByTicketId">
        DELETE FROM ticket_attachments WHERE ticket_id = #{ticketId}
    </delete>

</mapper>
