<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.igreen.domain.mapper.GroupMapper">

    <resultMap id="GroupResultMap" type="com.igreen.domain.entity.Group">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="tags" column="tags"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, description, tags, status, created_at, updated_at
    </sql>

    <select id="countByName" resultType="int">
        SELECT COUNT(*)
        FROM `groups`
        WHERE name = #{name}
    </select>

    <select id="selectById" resultMap="GroupResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM `groups`
        WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="GroupResultMap">
        SELECT id, name, description, tags, status, created_at, updated_at
        FROM `groups`
        ORDER BY created_at DESC
    </select>

    <insert id="insert" parameterType="com.igreen.domain.entity.Group">
        INSERT INTO `groups` (id, name, description, tags, status, created_at, updated_at)
        VALUES (#{id}, #{name}, #{description}, #{tags}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.igreen.domain.entity.Group">
        UPDATE `groups`
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="tags != null">tags = #{tags},</if>
            <if test="status != null">status = #{status},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM `groups` WHERE id = #{id}
    </delete>

</mapper>
