package com.igreen.domain.mapper;

import com.baomidou.mybatisplus.core.conditions.query.LambdaQueryWrapper;
import com.igreen.domain.entity.User;
import com.igreen.domain.enums.CountryCode;
import com.igreen.domain.enums.UserRole;
import com.igreen.domain.enums.UserStatus;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.jdbc.AutoConfigureTestDatabase;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.test.context.ActiveProfiles;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;
import java.util.Optional;

import static org.junit.jupiter.api.Assertions.*;

@SpringBootTest
@AutoConfigureTestDatabase(replace = AutoConfigureTestDatabase.Replace.NONE)
@ActiveProfiles("test")
@Transactional
@DisplayName("UserMapper 集成测试")
class UserMapperIntegrationTest {

    @Autowired
    private UserMapper userMapper;

    private User testUser;

    @BeforeEach
    void setUp() {
        // 清理测试数据
        userMapper.delete(new LambdaQueryWrapper<>());

        // 创建测试用户
        testUser = User.builder()
                .id("test-user-001")
                .name("测试用户")
                .username("testuser")
                .email("test@example.com")
                .hashedPassword("encoded_password")
                .role(UserRole.ENGINEER)
                .status(UserStatus.ACTIVE)
                .country("TH")
                .groupId("group-001")
                .build();
    }

    @Nested
    @DisplayName("基础 CRUD 操作测试")
    class BasicCRUDTests {

        @Test
        @DisplayName("插入用户成功")
        void insert_ShouldReturnOne() {
            int result = userMapper.insert(testUser);
            assertEquals(1, result);
        }

        @Test
        @DisplayName("根据ID查询用户")
        void selectById_ShouldReturnUser() {
            userMapper.insert(testUser);

            User found = userMapper.selectById("test-user-001");
            assertNotNull(found);
            assertEquals("testuser", found.getUsername());
        }

        @Test
        @DisplayName("查询不存在的用户应返回null")
        void selectById_NotExisting_ShouldReturnNull() {
            User found = userMapper.selectById("non-existent-id");
            assertNull(found);
        }

        @Test
        @DisplayName("更新用户信息")
        void updateById_ShouldUpdateUser() {
            userMapper.insert(testUser);

            testUser.setName("更新后的用户名");
            int result = userMapper.updateById(testUser);
            assertEquals(1, result);

            User updated = userMapper.selectById("test-user-001");
            assertEquals("更新后的用户名", updated.getName());
        }

        @Test
        @DisplayName("删除用户")
        void deleteById_ShouldDeleteUser() {
            userMapper.insert(testUser);

            int result = userMapper.deleteById("test-user-001");
            assertEquals(1, result);

            User deleted = userMapper.selectById("test-user-001");
            assertNull(deleted);
        }

        @Test
        @DisplayName("查询所有用户")
        void selectList_ShouldReturnAllUsers() {
            userMapper.insert(testUser);

            User user2 = User.builder()
                    .id("test-user-002")
                    .name("测试用户2")
                    .username("testuser2")
                    .email("test2@example.com")
                    .hashedPassword("encoded_password")
                    .role(UserRole.MANAGER)
                    .status(UserStatus.ACTIVE)
                    .country("TH")
                    .groupId("group-001")
                    .build();
            userMapper.insert(user2);

            List<User> users = userMapper.selectList(null);
            assertTrue(users.size() >= 2);
        }
    }

    @Nested
    @DisplayName("自定义查询方法测试")
    class CustomQueryTests {

        @Test
        @DisplayName("根据ID查询用户及其分组")
        void selectByIdWithGroup_ShouldReturnUser() {
            userMapper.insert(testUser);

            Optional<User> found = userMapper.selectByIdWithGroup("test-user-001");
            assertTrue(found.isPresent());
            assertEquals("testuser", found.get().getUsername());
        }

        @Test
        @DisplayName("根据角色和状态查询用户")
        void selectByRoleAndStatus_ShouldReturnFilteredUsers() {
            userMapper.insert(testUser);

            User inactiveUser = User.builder()
                    .id("test-user-002")
                    .name("不活跃用户")
                    .username("inactiveuser")
                    .email("inactive@example.com")
                    .hashedPassword("encoded_password")
                    .role(UserRole.ENGINEER)
                    .status(UserStatus.INACTIVE)
                    .country("TH")
                    .groupId("group-001")
                    .build();
            userMapper.insert(inactiveUser);

            List<User> activeEngineers = userMapper.selectByRoleAndStatus(
                    UserRole.ENGINEER.name(),
                    UserStatus.ACTIVE.name()
            );

            assertTrue(activeEngineers.stream().anyMatch(u -> u.getId().equals("test-user-001")));
            assertFalse(activeEngineers.stream().anyMatch(u -> u.getId().equals("test-user-002")));
        }

        @Test
        @DisplayName("根据分组ID查询用户")
        void selectByGroupId_ShouldReturnGroupUsers() {
            userMapper.insert(testUser);

            User otherGroupUser = User.builder()
                    .id("test-user-002")
                    .name("其他分组用户")
                    .username("othergroupuser")
                    .email("othergroup@example.com")
                    .hashedPassword("encoded_password")
                    .role(UserRole.ENGINEER)
                    .status(UserStatus.ACTIVE)
                    .country("TH")
                    .groupId("group-999")  // 不同分组
                    .build();
            userMapper.insert(otherGroupUser);

            List<User> groupUsers = userMapper.selectByGroupId("group-001");

            assertTrue(groupUsers.stream().anyMatch(u -> u.getId().equals("test-user-001")));
            assertFalse(groupUsers.stream().anyMatch(u -> u.getId().equals("test-user-002")));
        }

        @Test
        @DisplayName("根据邮箱查询用户")
        void selectByEmail_ShouldReturnUser() {
            userMapper.insert(testUser);

            Optional<User> found = userMapper.selectByEmail("test@example.com");
            assertTrue(found.isPresent());
            assertEquals("testuser", found.get().getUsername());
        }

        @Test
        @DisplayName("根据邮箱查询不存在的用户应返回空")
        void selectByEmail_NotExisting_ShouldReturnEmpty() {
            Optional<User> found = userMapper.selectByEmail("nonexistent@example.com");
            assertFalse(found.isPresent());
        }

        @Test
        @DisplayName("根据用户名查询用户")
        void selectByUsername_ShouldReturnUser() {
            userMapper.insert(testUser);

            Optional<User> found = userMapper.selectByUsername("testuser");
            assertTrue(found.isPresent());
            assertEquals("test-user-001", found.get().getId());
        }

        @Test
        @DisplayName("根据用户名和国家查询用户")
        void selectByUsernameAndCountry_ShouldReturnUser() {
            userMapper.insert(testUser);

            Optional<User> found = userMapper.selectByUsernameAndCountry("testuser", "TH");
            assertTrue(found.isPresent());
        }

        @Test
        @DisplayName("根据用户名和不匹配的国家查询应返回空")
        void selectByUsernameAndCountry_WrongCountry_ShouldReturnEmpty() {
            userMapper.insert(testUser);

            Optional<User> found = userMapper.selectByUsernameAndCountry("testuser", "ID");
            assertFalse(found.isPresent());
        }

        @Test
        @DisplayName("统计分组内的用户数量")
        void countByGroupId_ShouldReturnCorrectCount() {
            userMapper.insert(testUser);

            User user2 = User.builder()
                    .id("test-user-002")
                    .name("测试用户2")
                    .username("testuser2")
                    .email("test2@example.com")
                    .hashedPassword("encoded_password")
                    .role(UserRole.ENGINEER)
                    .status(UserStatus.ACTIVE)
                    .country("TH")
                    .groupId("group-001")
                    .build();
            userMapper.insert(user2);

            Integer count = userMapper.countByGroupId("group-001");
            assertEquals(2, count);
        }

        @Test
        @DisplayName("统计空分组的用户数量应返回0")
        void countByGroupId_EmptyGroup_ShouldReturnZero() {
            Integer count = userMapper.countByGroupId("empty-group");
            assertEquals(0, count);
        }
    }

    @Nested
    @DisplayName("边界条件测试")
    class EdgeCaseTests {

        @Test
        @DisplayName("插入用户并立即查询")
        void insertAndImmediateSelect_ShouldWork() {
            int result = userMapper.insert(testUser);
            assertEquals(1, result);

            User found = userMapper.selectById("test-user-001");
            assertNotNull(found);
        }

        @Test
        @DisplayName("更新不存在的用户应返回0")
        void updateById_NotExisting_ShouldReturnZero() {
            int result = userMapper.updateById(testUser);
            assertEquals(0, result);
        }

        @Test
        @DisplayName("删除不存在的用户应返回0")
        void deleteById_NotExisting_ShouldReturnZero() {
            int result = userMapper.deleteById("non-existent-id");
            assertEquals(0, result);
        }

        @Test
        @DisplayName("查询空列表")
        void selectList_EmptyTable_ShouldReturnEmptyList() {
            List<User> users = userMapper.selectList(null);
            assertTrue(users.isEmpty());
        }
    }

    @Nested
    @DisplayName("枚举类型测试")
    class EnumTypeTests {

        @Test
        @DisplayName("插入不同角色的用户")
        void insert_DifferentRoles_ShouldSucceed() {
            UserRole[] roles = {UserRole.ADMIN, UserRole.MANAGER, UserRole.ENGINEER};

            for (int i = 0; i < roles.length; i++) {
                User user = User.builder()
                        .id("test-user-" + i)
                        .name("测试用户" + i)
                        .username("testuser" + i)
                        .email("test" + i + "@example.com")
                        .hashedPassword("encoded_password")
                        .role(roles[i])
                        .status(UserStatus.ACTIVE)
                        .country("TH")
                        .groupId("group-001")
                        .build();

                int result = userMapper.insert(user);
                assertEquals(1, result);
            }
        }

        @Test
        @DisplayName("插入不同状态的用户")
        void insert_DifferentStatus_ShouldSucceed() {
            UserStatus[] statuses = {UserStatus.ACTIVE, UserStatus.INACTIVE};

            for (int i = 0; i < statuses.length; i++) {
                User user = User.builder()
                        .id("test-user-" + i)
                        .name("测试用户" + i)
                        .username("statususer" + i)
                        .email("status" + i + "@example.com")
                        .hashedPassword("encoded_password")
                        .role(UserRole.ENGINEER)
                        .status(statuses[i])
                        .country("TH")
                        .groupId("group-001")
                        .build();

                int result = userMapper.insert(user);
                assertEquals(1, result);
            }
        }

        @Test
        @DisplayName("插入不同国家的用户")
        void insert_DifferentCountries_ShouldSucceed() {
            String[] countries = {"TH", "ID", "BR"};

            for (int i = 0; i < countries.length; i++) {
                User user = User.builder()
                        .id("test-user-" + i)
                        .name("测试用户" + i)
                        .username("countryuser" + i)
                        .email("country" + i + "@example.com")
                        .hashedPassword("encoded_password")
                        .role(UserRole.ENGINEER)
                        .status(UserStatus.ACTIVE)
                        .country(countries[i])
                        .groupId("group-001")
                        .build();

                int result = userMapper.insert(user);
                assertEquals(1, result);
            }
        }
    }

    @Nested
    @DisplayName("查询条件组合测试")
    class QueryCombinationTests {

        @Test
        @DisplayName("根据角色查询排除其他角色")
        void selectByRole_ShouldExcludeOtherRoles() {
            // 插入不同角色的用户
            User admin = User.builder()
                    .id("admin-001")
                    .name("管理员")
                    .username("admin")
                    .email("admin@example.com")
                    .hashedPassword("encoded_password")
                    .role(UserRole.ADMIN)
                    .status(UserStatus.ACTIVE)
                    .country("TH")
                    .groupId("group-001")
                    .build();
            userMapper.insert(admin);

            User engineer = User.builder()
                    .id("engineer-001")
                    .name("工程师")
                    .username("engineer")
                    .email("engineer@example.com")
                    .hashedPassword("encoded_password")
                    .role(UserRole.ENGINEER)
                    .status(UserStatus.ACTIVE)
                    .country("TH")
                    .groupId("group-001")
                    .build();
            userMapper.insert(engineer);

            // 查询 ENGINEER 角色
            List<User> engineers = userMapper.selectByRoleAndStatus(
                    UserRole.ENGINEER.name(),
                    UserStatus.ACTIVE.name()
            );

            assertEquals(1, engineers.size());
            assertEquals("engineer-001", engineers.get(0).getId());
        }

        @Test
        @DisplayName("根据状态查询排除其他状态")
        void selectByStatus_ShouldExcludeOtherStatus() {
            // 插入不同状态的用户
            User activeUser = User.builder()
                    .id("active-001")
                    .name("活跃用户")
                    .username("activeuser")
                    .email("active@example.com")
                    .hashedPassword("encoded_password")
                    .role(UserRole.ENGINEER)
                    .status(UserStatus.ACTIVE)
                    .country("TH")
                    .groupId("group-001")
                    .build();
            userMapper.insert(activeUser);

            User inactiveUser = User.builder()
                    .id("inactive-001")
                    .name("不活跃用户")
                    .username("inactiveuser")
                    .email("inactive@example.com")
                    .hashedPassword("encoded_password")
                    .role(UserRole.ENGINEER)
                    .status(UserStatus.INACTIVE)
                    .country("TH")
                    .groupId("group-001")
                    .build();
            userMapper.insert(inactiveUser);

            // 查询 ACTIVE 状态
            List<User> activeUsers = userMapper.selectByRoleAndStatus(
                    UserRole.ENGINEER.name(),
                    UserStatus.ACTIVE.name()
            );

            assertEquals(1, activeUsers.size());
            assertEquals("active-001", activeUsers.get(0).getId());
        }
    }

    @Nested
    @DisplayName("Mapper 接口验证")
    class MapperInterfaceTests {

        @Test
        @DisplayName("UserMapper 应继承 BaseMapper")
        void userMapper_ShouldExtendBaseMapper() {
            assertTrue(userMapper instanceof com.baomidou.mybatisplus.core.mapper.BaseMapper);
        }

        @Test
        @DisplayName("UserMapper 应被 Spring 管理")
        void userMapper_ShouldBeSpringBean() {
            assertNotNull(userMapper);
        }

        @Test
        @DisplayName("UserMapper 应具有所有自定义方法")
        void userMapper_ShouldHaveAllCustomMethods() {
            // 验证所有自定义方法存在并可调用
            assertDoesNotThrow(() -> userMapper.selectByIdWithGroup("test-id"));
            assertDoesNotThrow(() -> userMapper.selectByRoleAndStatus("ROLE", "STATUS"));
            assertDoesNotThrow(() -> userMapper.selectByGroupId("group-id"));
            assertDoesNotThrow(() -> userMapper.selectByEmail("email@example.com"));
            assertDoesNotThrow(() -> userMapper.selectByUsername("username"));
            assertDoesNotThrow(() -> userMapper.selectByUsernameAndCountry("username", "TH"));
            assertDoesNotThrow(() -> userMapper.countByGroupId("group-id"));
        }
    }
}
